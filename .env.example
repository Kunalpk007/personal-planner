# ── Feature flags ─────────────────────────────────────────────────────────────
# All false by default. Flip to 'true' to enable Phase 2/3 features.

NEXT_PUBLIC_ENABLE_HISTORY_CHART=false
NEXT_PUBLIC_ENABLE_NOTION_SYNC=false
NEXT_PUBLIC_ENABLE_GCAL_SYNC=false
NEXT_PUBLIC_ENABLE_AI_SUMMARY=false
NEXT_PUBLIC_ENABLE_PUSH_NOTIFS=false
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# ── App identity ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_VERSION=2.0.0
NEXT_PUBLIC_STORAGE_KEY=kunals_planner_v2

# ── Required (no Firebase): Session secret for JWT auth ──────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ── Firebase client-side (public — safe in source, but fill in .env.local) ───
# These come from Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase server-side (NEVER commit — in .gitignore) ──────────────────────
# From Firebase Console → Project Settings → Service accounts → Generate key
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Phase 2 API keys (leave empty until feature is enabled) ───────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# ── Phase 3 (future) ──────────────────────────────────────────────────────────
# DATABASE_URL=
# NEXTAUTH_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
